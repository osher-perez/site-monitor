.venv/
venv/
ENV/
env/
python-worker/venv/
python-worker/.venv/

# Python Bytecode & Cache
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ipynb_checkpoints/
.ruff_cache/

# ==========================================
# 🔒 Environment & Secret Files (חסימה הרמטית)
# ==========================================
.env
.env.*
!.env.example

